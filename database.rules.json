{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".indexOn": ["role", "email"],
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "newData.hasChildren(['uid', 'email', 'displayName', 'role', 'createdAt']) && newData.child('uid').val() === $uid"
      }
    },
    "incomes": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'viewer'",
      "$incomeId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'viewer' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (data.exists() ? data.child('ownerId').val() === auth.uid : newData.child('ownerId').val() === auth.uid))"
      }
    },
    "ownerExpenses": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'viewer'",
      "$expenseId": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() !== 'viewer' && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (data.exists() ? data.child('ownerId').val() === auth.uid : newData.child('ownerId').val() === auth.uid))"
      }
    },
    "officeExpenses": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'viewer')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'viewer')",
      "$expenseId": {
        ".validate": "newData.hasChildren(['category', 'name', 'amount', 'month', 'year', 'description', 'createdAt'])"
      }
    },
    "fixedExpenses": {
      ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'viewer')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'viewer')",
      "$recordId": {
        ".validate": "newData.hasChildren(['id', 'month', 'year', 'amounts'])"
      }
    },
    "settings": {
      ".read": "auth != null",
      "usdToPkr": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
        ".validate": "newData.isNumber() && newData.val() > 0"
      },
      "exchangeRates": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    }
  }
}
