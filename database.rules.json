{
  "rules": {
    "users": {
      ".read": "auth != null",
      ".indexOn": ["role", "email"],
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".validate": "newData.hasChildren(['uid', 'email', 'displayName', 'role', 'createdAt']) && newData.child('uid').val() === $uid"
      }
    },
    "incomes": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "ownerExpenses": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "officeExpenses": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "fixedExpenses": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "employees": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "employeePayslips": {
      "$employeeId": {
        ".read": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'viewer' || (root.child('users').child(auth.uid).child('role').val() === 'employee' && root.child('users').child(auth.uid).child('employeeId').val() === $employeeId && root.child('users').child(auth.uid).child('accountStatus').val() === 'verified'))",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || root.child('users').child(auth.uid).child('role').val() === 'viewer')"
      }
    },
    "employeeAttendance": {
      ".read": "auth != null",
      "$employeeId": {
        "$date": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'employee' && root.child('users').child(auth.uid).child('employeeId').val() === $employeeId && root.child('users').child(auth.uid).child('accountStatus').val() === 'verified'))"
        }
      }
    },
    "employeeLeaveRequests": {
      ".read": "auth != null",
      "$employeeId": {
        "$requestId": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'admin' || (root.child('users').child(auth.uid).child('role').val() === 'employee' && root.child('users').child(auth.uid).child('employeeId').val() === $employeeId && root.child('users').child(auth.uid).child('accountStatus').val() === 'verified'))"
        }
      }
    },
    "settings": {
      ".read": "auth != null",
      "usdToPkr": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      },
      "rolePermissions": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    }
  }
}
